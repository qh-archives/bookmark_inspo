{
  "manifest_version": 3,
  "name": "Twitter Bookmarks Canvas",
  "version": "1.1",
  "description": "Automatically sends your Twitter bookmarks to your canvas app",
  "permissions": ["storage"],
  "host_permissions": [
    "https://twitter.com/*",
    "https://x.com/*",
    "http://localhost:3001/*",
    "http://127.0.0.1:3001/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://twitter.com/*", "https://x.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Bookmarks Canvas"
  },
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  }
}
